# ============================================================
# multi_agent_otel_eval — provider configuration
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ============================================================

# ------------------------------------------------------------
# OPTION A: Azure OpenAI  (reference setup for this demo)
# ------------------------------------------------------------
# Uses API-key auth against an IP-allowlisted endpoint — no interactive
# MS login, so evaluation runs never get interrupted. RUN LOCALLY: Google
# Colab cannot reach an IP-allowlisted Azure endpoint.
# OPENAI_API_KEY=your-azure-key
# OPENAI_BASE_URL=https://<resource>.openai.azure.com
# OPENAI_API_VERSION=2025-04-01-preview
# AGENT_MODEL=gpt-4o            # your deployment name
# JUDGE_MODEL=gpt-4o            # your deployment name

# Azure API Management gateway (optional)
# OPENAI_APIM_HEADER_NAME=Your-Custom-Subscription-Key-Header
# OPENAI_APIM_SUBSCRIPTION_KEY=your-subscription-key

# ------------------------------------------------------------
# OPTION B: OpenAI (direct)  — works on Colab and locally
# ------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# AGENT_MODEL=gpt-4o
# JUDGE_MODEL=gpt-4o

# ------------------------------------------------------------
# OPTION C: Ollama (local, free)
# ------------------------------------------------------------
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# AGENT_MODEL=llama3
# JUDGE_MODEL=llama3

# ------------------------------------------------------------
# OPTION D: Groq
# ------------------------------------------------------------
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# AGENT_MODEL=llama-3.1-70b-versatile
# JUDGE_MODEL=llama-3.1-70b-versatile

# ------------------------------------------------------------
# OPTION E: Together AI
# ------------------------------------------------------------
# OPENAI_API_KEY=your-together-key
# OPENAI_BASE_URL=https://api.together.xyz/v1
# AGENT_MODEL=meta-llama/Llama-3-70b-chat-hf
# JUDGE_MODEL=meta-llama/Llama-3-70b-chat-hf

# ------------------------------------------------------------
# OPTION F: LM Studio (local)
# ------------------------------------------------------------
# OPENAI_API_KEY=lm-studio
# OPENAI_BASE_URL=http://localhost:1234/v1
# AGENT_MODEL=your-loaded-model-name
# JUDGE_MODEL=your-loaded-model-name

# ------------------------------------------------------------
# Optional: Tavily (enables real web search)
# ------------------------------------------------------------
# TAVILY_API_KEY=tvly-...

# ------------------------------------------------------------
# Evaluation settings (optional — defaults shown)
# ------------------------------------------------------------
# EVAL_PASS_THRESHOLD=0.7
# RULE_WEIGHT=0.4
# LLM_WEIGHT=0.6
# QUICK_TEST_N=10
# MIND2WEB_TARGET_TASKS=300
